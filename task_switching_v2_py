        "import numpy as np\n",
        "\n",
        "# ============================================================\n",
        "# Mess3: edge-emitting HMM implementation\n",
        "# T[token, from_state, to_state] = Pr(token x, state j | state i)\n",
        "# Parameters: A: x=0.15, alpha=0.6 / B: x=0.15, alpha=0.3\n",
        "# ============================================================\n",
        "\n",
        "def make_mess3(x, alpha, n_states=3):\n",
        "    T = np.zeros((n_states, n_states, n_states))\n",
        "    for i in range(n_states):\n",
        "        for j in range(n_states):\n",
        "            p_trans = x if i == j else (1 - x) / (n_states - 1)\n",
        "            for tok in range(n_states):\n",
        "                p_emit = alpha if tok == j else (1 - alpha) / (n_states - 1)\n",
        "                T[tok, i, j] = p_trans * p_emit\n",
        "    return T\n",
        "\n",
        "def stationary_dist(T):\n",
        "    T_marg = T.sum(axis=0)\n",
        "    vals, vecs = np.linalg.eig(T_marg.T)\n",
        "    stat = np.real(vecs[:, np.argmax(np.real(vals))])\n",
        "    return stat / stat.sum()\n",
        "\n",
        "def generate_seq(T, length, rng):\n",
        "    n_states = T.shape[1]\n",
        "    stat = stationary_dist(T)\n",
        "    state = rng.choice(n_states, p=stat)\n",
        "    tokens = []\n",
        "    for _ in range(length):\n",
        "        joint = T[:, state, :].flatten()\n",
        "        joint /= joint.sum()\n",
        "        idx = rng.choice(len(joint), p=joint)\n",
        "        tok = idx // n_states\n",
        "        state = idx % n_states\n",
        "        tokens.append(tok)\n",
        "    return np.array(tokens)\n",
        "\n",
        "def compute_beliefs(T, sequence):\n",
        "    stat = stationary_dist(T)\n",
        "    belief = stat.copy()\n",
        "    beliefs = []\n",
        "    for tok in sequence:\n",
        "        new_belief = belief @ T[tok]\n",
        "        new_belief /= new_belief.sum()\n",
        "        belief = new_belief\n",
        "        beliefs.append(belief.copy())\n",
        "    return np.array(beliefs)\n",
        "\n",
        "def generate_pure_seqs(T, n_seqs, seq_len, rng):\n",
        "    seqs, bels = [], []\n",
        "    for _ in range(n_seqs):\n",
        "        seq = generate_seq(T, seq_len + 1, rng)\n",
        "        bel = compute_beliefs(T, seq[:-1])\n",
        "        seqs.append(seq)\n",
        "        bels.append(bel)\n",
        "    return np.array(seqs), np.array(bels)\n",
        "\n",
        "def generate_switch_seqs(T_A, T_B, n_seqs, seq_len, switch_point, rng):\n",
        "    seqs, labels = [], []\n",
        "    for _ in range(n_seqs):\n",
        "        seg_A = generate_seq(T_A, switch_point, rng)\n",
        "        seg_B = generate_seq(T_B, seq_len - switch_point + 1, rng)\n",
        "        seq = np.concatenate([seg_A, seg_B])\n",
        "        seqs.append(seq)\n",
        "        lab = np.array([0]*switch_point + [1]*(seq_len - switch_point))\n",
        "        labels.append(lab)\n",
        "    return np.array(seqs), np.array(labels)\n",
        "\n",
        "# Parameters\n",
        "X = 0.15\n",
        "ALPHA_A = 0.6\n",
        "ALPHA_B = 0.3\n",
        "N_STATES = 3\n",
        "VOCAB_SIZE = N_STATES\n",
        "SEQ_LEN = 32\n",
        "SWITCH_POINT = 16\n",
        "N_PURE = 10000\n",
        "N_SWITCH = 2000\n",
        "rng = np.random.default_rng(42)\n",
        "\n",
        "T_A = make_mess3(X, ALPHA_A)\n",
        "T_B = make_mess3(X, ALPHA_B)\n",
        "\n",
        "# Training data: pure A + pure B + switching sequences\n",
        "seqs_A, bels_A = generate_pure_seqs(T_A, N_PURE, SEQ_LEN, rng)\n",
        "seqs_B, bels_B = generate_pure_seqs(T_B, N_PURE, SEQ_LEN, rng)\n",
        "seqs_SW, labels_SW = generate_switch_seqs(T_A, T_B, N_SWITCH, SEQ_LEN, SWITCH_POINT, rng)\n",
        "\n",
        "all_seqs = np.concatenate([seqs_A, seqs_B, seqs_SW], axis=0)\n",
        "shuffle_idx = np.random.permutation(len(all_seqs))\n",
        "all_seqs = all_seqs[shuffle_idx]\n",
        "\n",
        "total_tokens = len(all_seqs) * SEQ_LEN\n",
        "print(f\"T_A shape: {T_A.shape}\")\n",
        "print(f\"Stationary dist A: {stationary_dist(T_A).round(3)}\")\n",
        "print(f\"Stationary dist B: {stationary_dist(T_B).round(3)}\")\n",
        "print(f\"Total training seqs: {len(all_seqs)}\")\n",
        "print(f\"Pure A: {N_PURE}, Pure B: {N_PURE}, Switch: {N_SWITCH}\")\n",
        "print(f\"Total tokens (before epoch): {total_tokens:,}\")\n",
        "\n",
