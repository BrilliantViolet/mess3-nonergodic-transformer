        "from sklearn.linear_model import LinearRegression\n",
        "\n",
        "def get_belief_subspace(model, seqs, beliefs, device, n_samples=1000):\n",
        "    model.eval()\n",
        "    all_acts, all_bels = [], []\n",
        "    with torch.no_grad():\n",
        "        for i in range(min(n_samples, len(seqs))):\n",
        "            x = torch.tensor(seqs[i:i+1, :-1], dtype=torch.long).to(device)\n",
        "            _, residual = model(x, return_residual=True)\n",
        "            acts = residual[0].cpu().numpy()\n",
        "            all_acts.append(acts)\n",
        "            all_bels.append(beliefs[i])\n",
        "    all_acts = np.concatenate(all_acts, axis=0)\n",
        "    all_bels = np.concatenate(all_bels, axis=0)\n",
        "    reg = LinearRegression().fit(all_acts, all_bels)\n",
        "    W = reg.coef_\n",
        "    pred = reg.predict(all_acts)\n",
        "    ss_res = ((all_bels - pred) ** 2).sum()\n",
        "    ss_tot = ((all_bels - all_bels.mean(axis=0)) ** 2).sum()\n",
        "    r2 = 1 - ss_res / ss_tot\n",
        "    return W, r2\n",
        "\n",
        "def project_onto_subspace(acts, W):\n",
        "    U, _, _ = np.linalg.svd(W.T, full_matrices=False)\n",
        "    proj = acts @ U\n",
        "    energy = (proj ** 2).sum(axis=-1)\n",
        "    total = (acts ** 2).sum(axis=-1)\n",
        "    return energy / (total + 1e-8)\n",
        "\n",
        "def track_switching_cost(model, seqs_sw, T_A, T_B, W_A, W_B, device, switch_point, n_samples=200):\n",
        "    model.eval()\n",
        "    proj_A_by_pos = np.zeros(seqs_sw.shape[1] - 1)\n",
        "    proj_B_by_pos = np.zeros(seqs_sw.shape[1] - 1)\n",
        "    with torch.no_grad():\n",
        "        for i in range(min(n_samples, len(seqs_sw))):\n",
        "            x = torch.tensor(seqs_sw[i:i+1, :-1], dtype=torch.long).to(device)\n",
        "            _, residual = model(x, return_residual=True)\n",
        "            acts = residual[0].cpu().numpy()\n",
        "            pA = project_onto_subspace(acts, W_A)\n",
        "            pB = project_onto_subspace(acts, W_B)\n",
        "            proj_A_by_pos += pA\n",
        "            proj_B_by_pos += pB\n",
        "    proj_A_by_pos /= min(n_samples, len(seqs_sw))\n",
        "    proj_B_by_pos /= min(n_samples, len(seqs_sw))\n",
        "    return proj_A_by_pos, proj_B_by_pos\n",
        "\n",
        "W_A, r2_A = get_belief_subspace(model, seqs_A, bels_A, device)\n",
        "W_B, r2_B = get_belief_subspace(model, seqs_B, bels_B, device)\n",
        "print(f\"R2_A: {r2_A:.4f}, R2_B: {r2_B:.4f}\")\n",
        "\n",
        "proj_A, proj_B = track_switching_cost(\n",
        "    model, seqs_SW, T_A, T_B, W_A, W_B, device, SWITCH_POINT\n",
        ")\n",
        "\n",
        "diff = proj_A - proj_B\n",
        "crossover = None\n",
        "for i in range(SWITCH_POINT, len(diff)):\n",
        "    if diff[i] < 0:\n",
        "        crossover = i\n",
        "        break\n",
        "\n",
        "print(f\"Switch point: position {SWITCH_POINT}\")\n",
        "if crossover is not None:\n",
        "    print(f\"B dominance achieved at: position {crossover}\")\n",
        "    print(f\"Switching cost: {crossover - SWITCH_POINT} tokens\")\n",
        "else:\n",
        "    print(\"B dominance not achieved within sequence\")\n",
        "\n",
        "print(f\"\\nProjection A around switch: {proj_A[SWITCH_POINT-2:SWITCH_POINT+5].round(4)}\")\n",
        "print(f\"Projection B around switch: {proj_B[SWITCH_POINT-2:SWITCH_POINT+5].round(4)}\")\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "positions = np.arange(len(proj_A))\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "axes[0].plot(positions, proj_A, 'b-o', markersize=4, label='Projection onto A subspace')\n",
        "axes[0].plot(positions, proj_B, 'r-o', markersize=4, label='Projection onto B subspace')\n",
        "axes[0].axvline(x=SWITCH_POINT, color='k', linestyle='--', linewidth=2, label='Switch point')\n",
        "if crossover:\n",
        "    axes[0].axvline(x=crossover, color='g', linestyle='--', linewidth=2, label=f'Crossover (cost={crossover-SWITCH_POINT})')\n",
        "axes[0].set_xlabel('Token position')\n",
        "axes[0].set_ylabel('Projection energy (normalized)')\n",
        "axes[0].set_title('Residual Stream: A to B Subspace Transition')\n",
        "axes[0].legend(fontsize=8)\n",
        "axes[0].grid(True, alpha=0.3)\n",
        "\n",
        "axes[1].plot(positions, diff, 'g-o', markersize=4)\n",
        "axes[1].axvline(x=SWITCH_POINT, color='k', linestyle='--', linewidth=2, label='Switch point')\n",
        "axes[1].axhline(y=0, color='gray', linestyle='-', linewidth=1)\n",
        "axes[1].fill_between(positions, 0, diff, where=(diff > 0), alpha=0.3, color='blue', label='A dominant')\n",
        "axes[1].fill_between(positions, 0, diff, where=(diff < 0), alpha=0.3, color='red', label='B dominant')\n",
        "axes[1].set_xlabel('Token position')\n",
        "axes[1].set_ylabel('A energy - B energy')\n",
        "axes[1].set_title('Subspace Dominance Shift\\n(Crossover = switching cost)')\n",
        "axes[1].legend()\n",
        "axes[1].grid(True, alpha=0.3)\n",
        "\n",
        "plt.suptitle(f'Belief State Manifold Transition\\n(x={X}, alpha_A={ALPHA_A}, alpha_B={ALPHA_B}, switch at pos {SWITCH_POINT})', fontsize=12)\n",
        "plt.tight_layout()\n",
        "plt.savefig('projection_tracking.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "print(\"Figure saved as projection_tracking.png\")\n",
