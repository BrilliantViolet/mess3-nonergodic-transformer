        "# Compute ground truth beliefs for switching sequences\n",
        "def compute_switch_beliefs(T_A, T_B, seqs, switch_point):\n",
        "    bels = []\n",
        "    for seq in seqs:\n",
        "        seq_input = seq[:-1]\n",
        "        belief_seq = []\n",
        "        # Before switch: use T_A\n",
        "        bel_A = compute_beliefs(T_A, seq_input[:switch_point])\n",
        "        # After switch: continue from last A belief using T_B\n",
        "        last_belief = bel_A[-1]\n",
        "        bel_B = []\n",
        "        for tok in seq_input[switch_point:]:\n",
        "            new_belief = last_belief @ T_B[tok]\n",
        "            new_belief /= new_belief.sum()\n",
        "            last_belief = new_belief\n",
        "            bel_B.append(new_belief.copy())\n",
        "        full_bel = np.concatenate([bel_A, np.array(bel_B)], axis=0)\n",
        "        bels.append(full_bel)\n",
        "    return np.array(bels)\n",
        "\n",
        "bels_SW = compute_switch_beliefs(T_A, T_B, seqs_SW, SWITCH_POINT)\n",
        "\n",
        "print(f\"bels_SW shape: {bels_SW.shape}\")\n",
        "print(f\"Belief sum check at switch point: {bels_SW[:, SWITCH_POINT, :].sum(axis=1)[:5].round(3)}\")\n",
        "print(\"Switch sequence beliefs computed\")"
      ]
